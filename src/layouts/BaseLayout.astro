---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "ICF Danmark — International Coaching Federation, Denmark Charter Chapter" } = Astro.props;

const nav = [
  {
    href: "/icf-danmark", label: "ICF Danmark",
    children: [
      { href: "/om-icf", label: "Om ICF" },
      { href: "/om-coaching", label: "Om coaching" },
      { href: "/organisation", label: "Organisation" },
      { href: "/vedtaegter", label: "Vedtægter" },
    ],
  },
  {
    href: "/uddannelse-og-certificering", label: "Uddannelse og certificering",
    children: [
      { href: "/coachuddannelse", label: "Coachuddannelse" },
      { href: "/certificering", label: "Certificering" },
      { href: "/fornyelse", label: "Fornyelse af certificering" },
    ],
  },
  { href: "/aktiviteter", label: "Aktiviteter" },
  { href: "/nyheder", label: "Nyheder" },
  {
    href: "/bliv-medlem", label: "Bliv Medlem",
    children: [
      { href: "/bliv-medlem", label: "Bliv Medlem" },
      { href: "/medlemsfordele", label: "Medlemsfordele" },
    ],
  },
  {
    href: "/find-coach", label: "Find en Coach",
    children: [
      { href: "/hvorfor-vaelge-en-icf-coach", label: "Hvorfor vælge en ICF coach?" },
      { href: "/acc-pcc-mcc", label: "Hvad er ACC, PCC og MCC?" },
      { href: "/find-coach", label: "Søg efter en coach" },
    ],
  },
];
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | ICF Danmark</title>
    <!-- Plus Jakarta Sans — matches icf-chapters.org original -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans text-icf-blue bg-white antialiased">
    <!-- WCAG skip-to-content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-icf-navy focus:text-white focus:px-4 focus:py-2 focus:rounded"
    >
      Gå til indhold
    </a>

    <!-- Header — matches icf-chapters.org original (two rows: logo bar + nav bar) -->
    <header>
      <!-- Top bar: logo + contact -->
      <div class="bg-white">
        <div class="max-w-[1400px] mx-auto px-5 py-6 flex items-center justify-between">
          <a href="/">
            <img
              src="/uploads/icf-logo.png"
              alt="ICF Danmark"
              class="h-[75px]"
            />
          </a>
          <div class="hidden md:flex flex-col items-end text-sm text-icf-blue">
            <span class="font-bold tracking-wider uppercase text-xs">ICF CHAPTER DANMARK</span>
            <a href="mailto:kontakt@coachingfederation.dk" class="hover:text-icf-accent">kontakt@coachingfederation.dk</a>
          </div>
        </div>
      </div>

      <!-- Navigation bar -->
      <div class="bg-icf-blue">
        <nav class="max-w-[1400px] mx-auto hidden lg:flex" aria-label="Hovednavigation">
          {nav.map((item) => (
            <div class="relative group">
              <a
                href={item.href}
                class="block px-5 py-3 text-sm text-white/90 hover:text-white hover:bg-white/10 transition-colors"
              >
                {item.label}
              </a>
              {item.children && (
                <div class="absolute top-full left-0 hidden group-hover:block z-50">
                  <div class="bg-icf-navy shadow-lg min-w-[220px]">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="block px-5 py-3 text-xs text-white/80 hover:text-white hover:bg-white/10 border-b border-white/10 last:border-0"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))}
        </nav>

        <!-- Mobile menu toggle -->
        <div class="lg:hidden flex items-center justify-between px-5 py-3">
          <span class="text-white text-sm font-medium">Menu</span>
          <button
            id="mobile-menu-btn"
            class="text-white"
            aria-label="Åbn menu"
            aria-expanded="false"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile nav -->
      <nav id="mobile-menu" class="hidden lg:hidden bg-icf-navy px-6 pb-4" aria-label="Mobilnavigation">
        {nav.map((item) => (
          <div>
            <a
              href={item.href}
              class="block py-2 text-sm text-white hover:text-icf-accent border-b border-white/10"
            >
              {item.label}
            </a>
            {item.children && item.children.map((child) => (
              <a
                href={child.href}
                class="block py-2 pl-4 text-xs text-white/70 hover:text-icf-accent border-b border-white/5"
              >
                {child.label}
              </a>
            ))}
          </div>
        ))}
      </nav>
    </header>

    <!-- Main content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Newsletter signup -->
    <section class="bg-icf-bone py-12">
      <div class="max-w-[600px] mx-auto px-6 text-center">
        <h3 class="text-xl font-bold text-icf-navy mb-3">Tilmeld nyhedsbrev</h3>
        <p class="text-sm text-icf-dark mb-6">Få nyheder om events, netværk og coaching i Danmark direkte i din indbakke.</p>
        <form class="flex flex-col sm:flex-row gap-3" id="newsletter-form">
          <input
            type="email"
            name="email"
            placeholder="Din e-mail"
            required
            class="flex-1 px-4 py-3 rounded border border-gray-300 text-sm focus:outline-none focus:border-icf-blue"
          />
          <button
            type="submit"
            class="bg-icf-navy text-white px-6 py-3 rounded text-sm font-medium hover:bg-icf-blue transition-colors"
          >
            Tilmeld
          </button>
        </form>
      </div>
    </section>

    <!-- Footer — matches icf-chapters.org (bg #2b379b, three-column + legal bar) -->
    <footer class="bg-icf-blue mt-10 text-[15px] text-white">
      <div class="max-w-[1400px] mx-auto px-5 py-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-white">
          <!-- Column 1: Info -->
          <div>
            <h4 class="font-bold text-sm tracking-wider uppercase mb-4 text-white">ICF CHAPTER DANMARK</h4>
            <p class="text-white/80 text-sm leading-relaxed mb-3">
              ICF Denmark er en lokal afdeling af International Coach Federation der er en verdensomspændende interesseorganisation indenfor professionel coaching.
            </p>
            <p class="text-white/80 text-sm">
              <a href="mailto:kontakt@coachingfederation.dk" class="hover:text-white underline">kontakt@coachingfederation.dk</a>
            </p>
            <div class="flex gap-4 text-white/80 text-sm mt-3">
              <a href="https://facebook.com" class="hover:text-white transition-colors">Facebook</a>
              <a href="https://linkedin.com" class="hover:text-white transition-colors">LinkedIn</a>
            </div>
          </div>
          <!-- Column 2: Navigation -->
          <div>
            <h4 class="font-bold text-sm tracking-wider uppercase mb-4 text-white">Navigation</h4>
            <ul class="space-y-2 text-sm text-white/80">
              <li><a href="/icf-danmark" class="hover:text-white">ICF Danmark</a></li>
              <li><a href="/uddannelse-og-certificering" class="hover:text-white">Uddannelse og certificering</a></li>
              <li><a href="/aktiviteter" class="hover:text-white">Aktiviteter</a></li>
              <li><a href="/nyheder" class="hover:text-white">Nyheder</a></li>
              <li><a href="/bliv-medlem" class="hover:text-white">Bliv medlem</a></li>
            </ul>
          </div>
          <!-- Column 3: Discover -->
          <div>
            <h4 class="font-bold text-sm tracking-wider uppercase mb-4 text-white">Find en Coach</h4>
            <ul class="space-y-2 text-sm text-white/80">
              <li><a href="/find-coach" class="hover:text-white">Søg efter en coach</a></li>
              <li><a href="/hvorfor-vaelge-en-icf-coach" class="hover:text-white">Hvorfor vælge en ICF coach?</a></li>
              <li><a href="/acc-pcc-mcc" class="hover:text-white">Hvad er ACC, PCC og MCC?</a></li>
            </ul>
          </div>
        </div>
      </div>
      <!-- Legal bar -->
      <div class="border-t border-white/20">
        <div class="max-w-[1400px] mx-auto px-5 py-6 flex flex-wrap items-center justify-between text-sm text-white/70">
          <span>&copy; {new Date().getFullYear()} International Coaching Federation</span>
          <div class="flex gap-4">
            <a href="/privatlivspolitik" class="hover:text-white">Privacy policy ICF</a>
            <a href="/privatlivspolitik-chapter" class="hover:text-white">Privacy policy chapter</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile menu script -->
    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");
      btn?.addEventListener("click", () => {
        const open = menu?.classList.toggle("hidden");
        btn.setAttribute("aria-expanded", String(!open));
      });
    </script>
  </body>
</html>
