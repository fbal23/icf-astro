---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "ICF Danmark — International Coaching Federation, Denmark Charter Chapter" } = Astro.props;

const nav = [
  {
    href: "/icf-danmark", label: "ICF Danmark",
    children: [
      { href: "/om-icf", label: "Om ICF" },
      { href: "/om-coaching", label: "Om coaching" },
      { href: "/organisation", label: "Organisation" },
      { href: "/vedtaegter", label: "Vedtægter" },
    ],
  },
  {
    href: "/uddannelse-og-certificering", label: "Uddannelse og certificering",
    children: [
      { href: "/coachuddannelse", label: "Coachuddannelse" },
      { href: "/certificering", label: "Certificering" },
      { href: "/fornyelse", label: "Fornyelse af certificering" },
    ],
  },
  { href: "/aktiviteter", label: "Aktiviteter" },
  { href: "/nyheder", label: "Nyheder" },
  {
    href: "/bliv-medlem", label: "Bliv Medlem",
    children: [
      { href: "/bliv-medlem", label: "Bliv Medlem" },
      { href: "/medlemsfordele", label: "Medlemsfordele" },
    ],
  },
  {
    href: "/find-coach", label: "Find en Coach",
    children: [
      { href: "/hvorfor-vaelge-en-icf-coach", label: "Hvorfor vælge en ICF coach?" },
      { href: "/acc-pcc-mcc", label: "Hvad er ACC, PCC og MCC?" },
      { href: "/find-coach", label: "Søg efter en coach" },
    ],
  },
];
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | ICF Danmark</title>
    <!-- System font stack — matches WordPress Kadence theme -->
  </head>
  <body class="font-sans text-icf-dark bg-white antialiased">
    <!-- WCAG skip-to-content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-icf-navy focus:text-white focus:px-4 focus:py-2 focus:rounded"
    >
      Gå til indhold
    </a>

    <!-- Header — matches WordPress Kadence header -->
    <header class="bg-icf-navy">
      <div class="max-w-[1200px] mx-auto px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
          <img
            src="/uploads/ICF_DenmarkCharterChapter_Horizontal_RGB_Negative.png"
            alt="ICF Danmark"
            class="h-10"
          />
          <span class="text-white font-bold text-lg hidden sm:inline">ICF Danmark</span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden lg:flex items-center gap-5" aria-label="Hovednavigation">
          {nav.map((item) => (
            <div class="relative group">
              <a
                href={item.href}
                class="text-sm text-white/90 hover:text-white transition-colors flex items-center gap-1 py-2"
              >
                {item.label}
                {item.children && (
                  <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
              </a>
              {item.children && (
                <div class="absolute top-full left-0 hidden group-hover:block pt-1 z-50">
                  <div class="bg-[#1A202C] rounded shadow-lg min-w-[200px]">
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="block px-4 py-3 text-xs text-gray-300 hover:text-white hover:bg-[#2D3748] border-b border-white/10 last:border-0"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))}
        </nav>

        <!-- Mobile menu toggle -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden text-white"
          aria-label="Åbn menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile nav -->
      <nav id="mobile-menu" class="hidden lg:hidden px-6 pb-4" aria-label="Mobilnavigation">
        {nav.map((item) => (
          <div>
            <a
              href={item.href}
              class="block py-2 text-sm text-white hover:text-icf-accent border-b border-white/10"
            >
              {item.label}
            </a>
            {item.children && item.children.map((child) => (
              <a
                href={child.href}
                class="block py-2 pl-4 text-xs text-white/70 hover:text-icf-accent border-b border-white/5"
              >
                {child.label}
              </a>
            ))}
          </div>
        ))}
      </nav>
    </header>

    <!-- Main content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Newsletter signup -->
    <section class="bg-icf-bone py-12">
      <div class="max-w-[600px] mx-auto px-6 text-center">
        <h3 class="text-xl font-bold text-icf-navy mb-3">Tilmeld nyhedsbrev</h3>
        <p class="text-sm text-icf-dark mb-6">Få nyheder om events, netværk og coaching i Danmark direkte i din indbakke.</p>
        <form class="flex flex-col sm:flex-row gap-3" id="newsletter-form">
          <input
            type="email"
            name="email"
            placeholder="Din e-mail"
            required
            class="flex-1 px-4 py-3 rounded border border-gray-300 text-sm focus:outline-none focus:border-icf-blue"
          />
          <button
            type="submit"
            class="bg-icf-navy text-white px-6 py-3 rounded text-sm font-medium hover:bg-icf-blue transition-colors"
          >
            Tilmeld
          </button>
        </form>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-icf-navy mt-0">
      <div class="max-w-[900px] mx-auto px-6 py-20 text-center">
        <h3 class="text-white font-bold text-sm tracking-wider uppercase mb-6">ICF CHAPTER DANMARK</h3>
        <p class="text-icf-bone text-sm mb-6 max-w-2xl mx-auto leading-relaxed">
          ICF Denmark er en lokal afdeling af International Coach Federation der er en verdensomspændende interesseorganisation indenfor professionel coaching. ICF Danmark har egne vedtægter, bestyrelse og præsident vedtaget og valgt af ICF Danmarks medlemmer på det årlige medlemsmøde.
        </p>
        <p class="text-icf-bone text-sm mb-6">
          E-mail: <a href="mailto:sekretaer@coachingfederation.dk" class="text-icf-accent hover:text-white underline">sekretaer@coachingfederation.dk</a>
        </p>
        <div class="flex justify-center gap-4 text-icf-bone text-sm mb-10">
          <a href="https://facebook.com" class="hover:text-white transition-colors">Facebook</a>
          <a href="https://linkedin.com" class="hover:text-white transition-colors">LinkedIn</a>
        </div>
        <div class="border-t border-white/10 pt-8 text-sm text-icf-bone">
          <p>&copy; {new Date().getFullYear()} ICF Chapter Danmark</p>
          <p class="mt-2"><a href="/privatlivspolitik" class="text-icf-bone/60 hover:text-white underline text-xs">Privatlivspolitik</a></p>
        </div>
      </div>
    </footer>

    <!-- Mobile menu script -->
    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");
      btn?.addEventListener("click", () => {
        const open = menu?.classList.toggle("hidden");
        btn.setAttribute("aria-expanded", String(!open));
      });
    </script>
  </body>
</html>
