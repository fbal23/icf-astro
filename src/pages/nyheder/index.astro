---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import { getCollection } from "astro:content";

const news = (await getCollection("news")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Nyheder" description="Seneste nyheder fra ICF Danmark">
  <Hero title="Nyheder" subtitle="Seneste nyt fra ICF Danmark" />

  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="space-y-8">
      {news.map((post) => (
        <a href={`/nyheder/${post.id}`} class="block bg-white rounded-xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
          <time class="text-sm text-gray-400" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("da-DK", { day: "numeric", month: "long", year: "numeric" })}
          </time>
          <h2 class="text-xl font-semibold mt-1 mb-2">{post.data.title}</h2>
          {post.data.excerpt && <p class="text-gray-600">{post.data.excerpt}</p>}
          <span class="text-icf-blue text-sm font-medium mt-3 inline-block">Læs mere →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
