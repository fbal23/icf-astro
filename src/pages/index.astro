---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="ICF Danmarks chapter – internationalt coachingfællesskab" description="ICF Danmark er det danske chapter af International Coaching Federation. Find certificerede coaches og bliv medlem.">

  <!-- Section 1: Hero Banner (matches icf-chapters.org) -->
  <section class="relative overflow-hidden">
    <img
      src="/uploads/chapter-events-banner.jpg"
      alt="Enjoy Great Learning — Engage in virtual and in-person ICF Chapter events and webinars"
      class="w-full h-auto"
      loading="eager"
    />
  </section>

  <!-- Section 2: Two-column layout — About + News (matches icf-chapters.org) -->
  <section style="max-width:1400px;margin:40px auto 55px">
    <div class="grid grid-cols-1 md:grid-cols-2">

      <!-- Left column: ICF Danmark About -->
      <div class="p-4">
        <p class="mb-2">&nbsp;</p>
        <h2 class="text-[22px] font-bold text-icf-blue mb-4">ICF Danmark</h2>
        <p class="text-icf-blue leading-relaxed mb-4">
          Vi er en non-profit, frivillig forening, der bygger på medlemmernes engagement for at skabe et fælles og stærkt fundament for udviklingen af professionel coaching i Danmark og i verden.
        </p>
        <p class="text-icf-blue leading-relaxed mb-6">
          ICF Danmark er det danske chapter af International Coaching Federation (ICF), der på verdensplan har 60.000 aktive medlemmer i 166 lande. I Danmark er der over 150 certificerede coaches. Alle medlemmer af den danske brancheorganisation har gennemgået en coachuddannelse akkrediteret af ICF (eller er under uddannelse), udvikler deres færdigheder løbende, følger ICF's etiske retningslinjer, og de fleste medlemmer vælger at sikre kvaliteten af deres coaching via ICF's certificeringsprogram.
        </p>
        <div class="text-center mt-6">
          <a href="/icf-danmark" class="inline-block bg-icf-blue text-white font-medium px-10 py-4 hover:bg-icf-navy transition-colors">
            ICF Danmark
          </a>
        </div>
      </div>

      <!-- Right column: Latest News -->
      <div class="p-4">
        <p class="mb-2">
          <strong class="text-icf-blue">Indkaldelse til den årlige Generalforsamling i ICF Danmark</strong>
        </p>
        <p class="text-icf-blue mb-3">
          <strong>Tirsdag den 24. marts 2026 kl. 15.00–16.30<br />
          Virtuel Generalforsamling</strong>
        </p>
        <p class="text-icf-blue leading-relaxed mb-3">
          Vi vil gerne invitere dig til at sætte X i kalenderen tirsdag den 24. marts 2026 kl. 15.00–16.30, hvor vi mødes på Zoom til ICF Danmarks årlige generalforsamling. Vi i bestyrelsen glæder os rigtig meget, til at fortælle dig om de planer vi arbejder med for ICF Danmark det næste års tid.
        </p>
        <p class="text-icf-blue leading-relaxed mb-6">
          Hvis du ønsker at deltage på Generalforsamlingen, bedes du tilmelde dig på e-mail <a href="mailto:sekretaer@coachingfederation.dk" class="text-icf-blue hover:text-icf-accent underline">sekretaer@coachingfederation.dk</a> senest 24 timer inden.<br />
          Alle tilmeldte vil dagen inden Generalforsamlingen modtage et Zoom-link til brug for deltagelse på Generalforsamlingen.
        </p>
        <div class="text-center mt-6">
          <a href="/nyheder" class="inline-block bg-icf-blue text-white font-medium px-10 py-4 hover:bg-icf-navy transition-colors">
            Se alle nyheder
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Section 3: Akkrediterede uddannelsesudbydere (matches icf-chapters.org .news.nb3 — 3 direct children) -->
  <section style="max-width:1400px;margin:0 auto" class="flex flex-col md:flex-row">
    <div class="flex-1">
      <div>
        <img src="/uploads/icf-original/partners/partner-expand.png" alt="EXPAND Coachuddannelse" class="w-full h-[340px] object-cover" />
      </div>
      <div class="py-[74px] text-center">
        <a href="#" class="inline-block bg-icf-blue text-white font-medium px-10 py-4 hover:bg-icf-navy transition-colors">
          EXPAND
        </a>
      </div>
    </div>
    <div class="flex-1">
      <div>
        <img src="/uploads/icf-original/partners/partner-sofia-manning.png" alt="Danmarks Førende Coachuddannelse" class="w-full h-[340px] object-cover" />
      </div>
      <div class="py-[74px] text-center">
        <a href="#" class="inline-block bg-icf-blue text-white font-medium px-10 py-4 hover:bg-icf-navy transition-colors">
          SOFIA MANNING
        </a>
      </div>
    </div>
    <div class="flex-1">
      <div>
        <img src="/uploads/icf-original/partners/partner-grow2.png" alt="GROW2" class="w-full h-[340px] object-cover" />
      </div>
      <div class="py-[74px] text-center">
        <a href="#" class="inline-block bg-icf-blue text-white font-medium px-10 py-4 hover:bg-icf-navy transition-colors">
          GROW2
        </a>
      </div>
    </div>
  </section>

  <!-- Section 4+5: Find Coach + Activities side-by-side (matches icf-chapters.org .blocs) -->
  <section style="max-width:1400px;margin:0 auto 40px">
    <hr class="border-icf-border mb-8" />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Find coach bloc -->
      <div class="border border-icf-border p-8 flex flex-col justify-between">
        <p class="text-icf-blue leading-relaxed mb-6">
          Her finder du din coach blandt vores medlemmer. Du kan søge på credential niveau, region, sprog og speciale og find den coach, der passer til dig.
        </p>
        <div>
          <a href="/find-coach" class="inline-block bg-icf-blue text-white font-medium px-8 py-4 hover:bg-icf-navy transition-colors">
            Find en coach
          </a>
        </div>
      </div>
      <!-- Activities bloc -->
      <div class="border border-icf-border p-8 flex flex-col justify-between">
        <p class="text-icf-blue leading-relaxed mb-6">
          Se vores næste aktiviteter!
        </p>
        <div>
          <a href="/aktiviteter" class="inline-block bg-icf-blue text-white font-medium px-8 py-4 hover:bg-icf-navy transition-colors">
            Aktiviteter
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: Bottom Banner — Enjoy Great Learning (matches icf-chapters.org) -->
  <section class="relative overflow-hidden">
    <img
      src="/uploads/chapter-events-banner.jpg"
      alt="Enjoy Great Learning — Engage in virtual and in-person ICF Chapter events and webinars"
      class="w-full h-auto"
      loading="lazy"
    />
  </section>

  <!-- Section 6: Bliv en del af fællesskabet (full-width, Astro addition) -->
  <section class="bg-icf-navy py-16 md:py-20">
    <div class="max-w-[700px] mx-auto px-6 text-center">
      <h2 class="text-[28px] font-bold text-white mb-6">Bliv en del af fællesskabet</h2>
      <p class="text-icf-bone mb-10 leading-relaxed">
        Som medlem af ICF Danmark er du en del af et stærkt fagligt netværk af professionelle coaches. Du får adgang til arrangementer, faglig sparring og mulighed for at blive listet i vores offentlige coach-directory.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/bliv-medlem" class="inline-block bg-icf-yellow text-icf-navy font-semibold px-8 py-3 rounded-md text-base hover:opacity-90 transition-opacity">
          Bliv Medlem
        </a>
        <a href="/find-coach" class="inline-block bg-white/10 border border-white text-white font-medium px-8 py-3 rounded-md text-base hover:bg-white/20 transition-colors">
          Find en Coach
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
