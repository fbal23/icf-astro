---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout title="Kontakt" description="Kontakt ICF Danmark — vi svarer gerne på spørgsmål om coaching, medlemskab og certificering.">
  <Hero title="Kontakt" />

  <section class="max-w-[900px] mx-auto px-6 py-12">
    <p class="text-icf-dark leading-relaxed mb-8">
      Har du spørgsmål til ICF Danmark, bestyrelsen eller vores aktiviteter? Udfyld formularen nedenfor, og vi vender tilbage til dig.
    </p>

    <hr class="border-icf-border mb-8" />

    <div class="grid md:grid-cols-3 gap-12">
      <!-- Contact form -->
      <div class="md:col-span-2">
        <h2 class="text-[24px] font-bold text-icf-navy mb-6">Send en besked</h2>
        <form id="contact-form" class="space-y-5">
          <div>
            <label for="name" class="block text-sm font-medium text-icf-dark mb-1">Navn *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Dit fulde navn"
              class="w-full max-w-md rounded-lg border border-icf-border text-sm p-3 bg-white"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-icf-dark mb-1">E-mail *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="din@email.dk"
              class="w-full max-w-md rounded-lg border border-icf-border text-sm p-3 bg-white"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-icf-dark mb-1">Besked *</label>
            <textarea
              id="message"
              name="message"
              required
              rows="8"
              placeholder="Skriv din besked her..."
              class="w-full max-w-md rounded-lg border border-icf-border text-sm p-3 bg-white"
            ></textarea>
          </div>
          <button
            type="submit"
            class="bg-icf-navy text-white font-medium px-6 py-3 rounded-md text-sm hover:bg-icf-navy/90 transition-colors"
          >
            Send besked
          </button>
        </form>
      </div>

      <!-- Sidebar -->
      <div>
        <div class="bg-icf-bone rounded-lg p-6 mb-6">
          <h3 class="text-lg font-bold text-icf-navy mb-3">Bestyrelsen</h3>
          <p class="text-sm mb-3">
            <a href="mailto:bestyrelsen@icf-danmark.dk" class="text-icf-blue hover:text-icf-accent underline">bestyrelsen@icf-danmark.dk</a>
          </p>
          <p class="text-sm text-icf-dark leading-relaxed">
            ICF Danmark er en frivillig forening ledet af en valgt bestyrelse. Vi bestræber os paa at svare inden for 5 hverdage.
          </p>
          <hr class="border-icf-border my-4" />
          <h4 class="font-bold text-icf-navy mb-2">Er du coach og vil oprette en profil?</h4>
          <p class="text-sm text-icf-dark">
            Coaches der er betalende medlemmer af ICF Danmark kan <a href="/find-coach" class="text-icf-blue hover:text-icf-accent underline">oprette en profil i vores directory her</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById("contact-form");
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      // For now, show a thank-you message. In production, this would submit to a Cloudflare Function.
      const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
      btn.textContent = "Besked sendt!";
      btn.disabled = true;
      btn.classList.add("opacity-60");
    });
  </script>
</BaseLayout>
