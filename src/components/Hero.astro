---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  cta?: { href: string; label: string };
}

const { title, subtitle, image, cta } = Astro.props;
---

<section class="relative bg-icf-navy text-white py-10 overflow-hidden">
  {image && (
    <img
      src={image}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-20"
      loading="eager"
    />
  )}
  <div class="relative max-w-[900px] mx-auto px-6 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-3">{title}</h1>
    {subtitle && <p class="text-lg text-icf-bone max-w-2xl mx-auto">{subtitle}</p>}
    {cta && (
      <a
        href={cta.href}
        class="inline-block mt-6 bg-icf-yellow text-icf-navy font-semibold px-6 py-3 rounded-lg hover:opacity-90 transition-opacity"
      >
        {cta.label}
      </a>
    )}
  </div>
</section>
