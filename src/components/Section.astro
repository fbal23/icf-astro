---
interface Props {
  title?: string;
  class?: string;
}

const { title, class: className = "" } = Astro.props;
---

<section class={`py-12 md:py-16 ${className}`}>
  <div class="max-w-[1100px] mx-auto px-6">
    {title && <h2 class="text-2xl md:text-3xl font-bold text-icf-navy mb-8">{title}</h2>}
    <slot />
  </div>
</section>
